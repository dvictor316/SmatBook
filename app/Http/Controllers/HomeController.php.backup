<?php

namespace App\Http\Controllers;

use App\Models\{Company, Subscription, User, DeploymentManager};
use Illuminate\Support\Facades\{Auth, DB, Log, Schema, Storage, Hash};
use Illuminate\Http\Request;

class HomeController extends Controller
{
    /**
     * MAIN HOME ROUTE - ROUTES ALL USERS TO THEIR CORRECT DASHBOARD
     * 
     * 5 Dashboard Types:
     * 1. Super Admin → /superadmin/dashboard
     * 2. Deployment Manager → /deployment/dashboard  
     * 3. Basic Plan → /dashboard (with Basic sidebar)
     * 4. Professional Plan → /dashboard (with Pro sidebar)
     * 5. Enterprise Plan → /dashboard (with Enterprise sidebar)
     */
    public function index()
    {
        $user = Auth::user();

        if (!$user) {
            Log::warning('Home accessed without authentication');
            return redirect()->route('login');
        }

        Log::info('=== HOME ROUTE ACCESSED ===', [
            'user_id' => $user->id,
            'email' => $user->email,
            'role' => $user->role,
        ]);

        // CRITICAL: Check deployment_managers table FIRST
        // This prevents deployment managers from being treated as super admins
        $isDeploymentManager = DeploymentManager::where('user_id', $user->id)->exists();
        
        if ($isDeploymentManager) {
            Log::info('User is DEPLOYMENT MANAGER (found in deployment_managers table)', [
                'user_id' => $user->id
            ]);
            return $this->handleDeploymentManagerRedirect($user);
        }

        // 1. SUPER ADMIN (only if NOT a deployment manager)
        if ($this->isSuperAdmin($user)) {
            Log::info('User is SUPER ADMIN', ['user_id' => $user->id]);
            return redirect()->route('super_admin.dashboard');
        }

        // 2. REGULAR TENANT (with plan-based dashboard)
        Log::info('User is REGULAR TENANT', ['user_id' => $user->id]);
        return $this->handleRegularUserRedirect($user);
    }

    /**
     * Handle deployment manager redirect
     */
    private function handleDeploymentManagerRedirect($user)
    {
        $manager = DeploymentManager::where('user_id', $user->id)->first();

        Log::info('Processing deployment manager', [
            'user_id' => $user->id,
            'status' => $manager->status ?? 'no_record',
            'is_verified' => $user->is_verified
        ]);

        // Needs verification
        if (!$manager || $manager->status === 'pending_info' || !$user->is_verified) {
            Log::info('→ Redirecting to verification form');
            return redirect()->route('manager.verification.form');
        }

        // Suspended/Rejected
        if (in_array($manager->status, ['suspended', 'inactive', 'rejected'])) {
            Log::warning('Manager account restricted', ['status' => $manager->status]);
            Auth::logout();
            return redirect()->route('login')->with('error', 'Your account has been ' . $manager->status);
        }

        // Pending approval
        if ($manager->status === 'pending') {
            Log::info('→ Manager pending approval');
            return redirect()->route('manager.pending.notice');
        }

        // Active - go to deployment dashboard
        if ($manager->status === 'active') {
            Log::info('→ Redirecting to DEPLOYMENT DASHBOARD');
            return redirect()->route('deployment.dashboard');
        }

        // Fallback
        return redirect()->route('manager.pending.notice');
    }

    /**
     * Handle regular user redirect - routes to correct plan dashboard
     */
    private function handleRegularUserRedirect($user)
    {
        // Check for subscription
        $subscription = Subscription::where('user_id', $user->id)->latest()->first();

        if (!$subscription) {
            Log::info('No subscription - redirecting to plans');
            return redirect()->route('membership-plans')
                ->with('info', 'Please select a plan to get started.');
        }

        Log::info('Subscription found', [
            'subscription_id' => $subscription->id,
            'plan' => $subscription->plan ?? $subscription->plan_name,
            'status' => $subscription->status,
            'payment_status' => $subscription->payment_status
        ]);

        // Check payment status
        if ($subscription->payment_status !== 'paid') {
            Log::info('→ Unpaid subscription, redirecting to checkout');
            return redirect()->route('saas.checkout', ['id' => $subscription->id]);
        }

        // Check if subscription is active
        if ($subscription->status !== 'Active') {
            Log::info('→ Inactive subscription, redirecting to setup');
            return redirect()->route('saas.setup', ['id' => $subscription->id]);
        }

        // Check for company
        $company = Company::where('user_id', $user->id)
            ->orWhere('owner_id', $user->id)
            ->first();

        if (!$company || empty($company->domain_prefix)) {
            Log::info('→ No company/domain, redirecting to setup');
            return redirect()->route('saas.setup', ['id' => $subscription->id]);
        }

        // Determine plan type for correct sidebar
        $planName = strtolower($subscription->plan ?? $subscription->plan_name ?? $company->plan ?? 'basic');
        
        Log::info('→ Routing to tenant workspace', [
            'plan' => $planName,
            'domain_prefix' => $company->domain_prefix
        ]);

        // Store plan in session for sidebar rendering
        session([
            'user_plan' => $planName,
            'company_id' => $company->id
        ]);

        // Redirect to tenant workspace
        $mainDomain = ltrim(config('session.domain', 'smatbook.com'), '.');
        $protocol = request()->secure() ? 'https://' : 'http://';
        $workspaceUrl = $protocol . $company->domain_prefix . '.' . $mainDomain . '/dashboard';

        return redirect()->away($workspaceUrl);
    }

    /**
     * Check if user is SUPER ADMIN (platform administrator, NOT deployment manager)
     */
    private function isSuperAdmin($user): bool
    {
        // Victor's email always gets super admin
        if ($user->email === 'donvictorlive@gmail.com') {
            return true;
        }

        $role = strtolower($user->role ?? '');
        
        // Only these specific roles for platform super admins
        return in_array($role, ['super_admin', 'superadmin']);
    }

    /**
     * Tenant Dashboard - Shows correct sidebar based on plan
     */
    public function dashboard()
    {
        $user = Auth::user();
        $company = Company::where('user_id', $user->id)->first();
        $subscription = Subscription::where('user_id', $user->id)
            ->where('payment_status', 'paid')
            ->where('status', 'Active')
            ->latest()
            ->first();

        if (!$subscription || !$company) {
            return redirect()->route('membership-plans');
        }

        // Determine which dashboard view to show based on plan
        $planName = strtolower($subscription->plan ?? $subscription->plan_name ?? 'basic');
        
        // Store in session for sidebar
        session(['user_plan' => $planName]);

        // All plans use the same dashboard view, but different sidebars
        // The sidebar is determined by the layout based on session('user_plan')
        return view('dashboard', compact('user', 'company', 'subscription'));
    }

    /**
     * Profile Management
     */
    public function profile()
    {
        $user = Auth::user();
        $profileFields = ['name', 'email', 'role', 'profile_photo', 'cover_photo'];
        $filledFields = 0;
        
        foreach ($profileFields as $field) {
            if (!empty($user->$field)) $filledFields++;
        }
        
        $completeness = ($filledFields / count($profileFields)) * 100;

        return view('Pages.profile', compact('user', 'completeness'));
    }

    public function updateProfileImages(Request $request)
    {
        $request->validate([
            'profile_photo' => 'nullable|image|mimes:jpeg,png,jpg|max:2048',
            'cover_photo' => 'nullable|image|mimes:jpeg,png,jpg|max:5120',
        ]);
        
        $user = Auth::user();
        
        if ($request->hasFile('profile_photo')) {
            if ($user->profile_photo) Storage::disk('public')->delete($user->profile_photo);
            $user->profile_photo = $request->file('profile_photo')->store('users/profiles', 'public');
        }
        
        if ($request->hasFile('cover_photo')) {
            if ($user->cover_photo) Storage::disk('public')->delete($user->cover_photo);
            $user->cover_photo = $request->file('cover_photo')->store('users/covers', 'public');
        }
        
        $user->save();
        return back()->with('success', 'Profile imagery updated successfully.');
    }

    public function updateProfile(Request $request)
    {
        $user = Auth::user();
        $user->update($request->only(['name'])); 
        return back()->with('success', 'Profile details updated.');
    }

    public function changePassword(Request $request)
    {
        $request->validate(['password' => 'required|confirmed|min:8']);
        $user = Auth::user();
        $user->password = Hash::make($request->password);
        $user->save();
        return back()->with('success', 'Password successfully changed.');
    }

    // Other view methods
    public function blankpage() { return view('Pages.blank-page'); }
    public function accountRequest(Request $request) { return view('pages.account-request'); }
}